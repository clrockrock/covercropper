{
  "name": "@covercropper/core",
  "version": "0.1.0-beta.0",
  "description": "Pure TypeScript geometry, state, constraints, and locale utilities for CoverCropper.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean"
  },
  "author": "CoverCropper contributors",
  "keywords": [
    "image-cropper",
    "cover-cropper",
    "avatar-cropper",
    "banner-cropper",
    "web-component",
    "cropper",
    "cover-safe",
    "image-editor",
    "typescript",
    "geometry"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clrockrock/covercropper.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/clrockrock/covercropper#readme",
  "bugs": {
    "url": "https://github.com/clrockrock/covercropper/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
